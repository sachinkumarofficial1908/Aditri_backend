# ========================================
# ADITRI BACKEND - ENVIRONMENT VARIABLES
# Copy this file to .env and fill values
# ========================================

NODE_ENV=development
PORT=10000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/aditri_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Admin credentials (change before production)
ADMIN_EMAIL=admin@aditri.com
ADMIN_PASSWORD=Admin@123#Secure
RECEIPT_SECRET_KEY=ACS-IDBI

# Payments
PAYMENT_METHODS=razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_CURRENCY=INR

# Email (Nodemailer - Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=aditri.c.services@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_TIMEOUT_MS=12000
FROM_EMAIL=aditri.c.services@gmail.com
FROM_NAME=Aditri Constructions Services

# Production email over HTTPS (recommended on Render free services)
# Set RESEND_API_KEY and use a verified sender in FROM_EMAIL.
RESEND_API_KEY=

# CORS - Frontend URL
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:10000
OAUTH_ALLOWED_CLIENT_URLS=http://localhost:5173,https://aditri-frontend2.vercel.app

# Google OAuth
# Callback URL must be added in Google Cloud Console as an authorized redirect URI.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=http://localhost:10000/api/auth/google/callback

# Firebase Admin token verification
FIREBASE_PROJECT_ID=your_firebase_project_id

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=aditri_uploads
