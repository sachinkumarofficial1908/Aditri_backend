# ========================================
# ADITRI BACKEND - ENVIRONMENT VARIABLES
# Copy this file to .env and fill values
# ========================================

NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/aditri_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Admin credentials (change before production)
ADMIN_EMAIL=admin@aditri.com
ADMIN_PASSWORD=Admin@123#Secure

# Email (Nodemailer - Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=aditri.c.services@gmail.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=aditri.c.services@gmail.com
FROM_NAME=Aditri Constructions Services

# CORS - Frontend URL
CLIENT_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
